{
  "name": "cusion-bad-apple",
  "version": "1.0.0",
  "description": "Browser-based video to Minecraft cushion datapack generator",
  "main": "dist/index.js",
  "packageManager": "pnpm@11.10.0+",
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit && vue-tsc --noEmit -p tsconfig.web.json",
    "start": "tsc && node dist/index.js",
    "web:dev": "vite",
    "web:build": "vite build",
    "web:preview": "vite preview"
  },
  "dependencies": {
    "@arco-design/web-vue": "^2.58.0",
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@types/node": "^26.1.1",
    "jszip": "^3.10.1",
    "path-browserify": "^1.0.1",
    "vue": "^3.5.40"
  },
  "devDependencies": {
    "@types/path-browserify": "^1.0.3",
    "@vitejs/plugin-vue": "^6.0.8",
    "playwright": "^1.61.1",
    "typescript": "^5.5.3",
    "vite": "^8.1.5",
    "vue-tsc": "^3.3.7"
  },
  "private": true
}
